      <p>And that is exactly what we want.</p>
      <ul class="bullets" style="margin-top:10px;">
        <li>Different teams, different choices</li>
        <li>Different metrics, different totals</li>
        <li>This validates BVIF across experiences</li>
      </ul>
    </div>
  </div>
</section>

</div><!-- /deck -->

<div class="notes-panel" id="notes">
  <h4>Presenter notes</h4>
  <div id="notes-content"></div>
</div>

<div class="counter"><span id="curr">1</span> / <span id="total">1</span></div>
<div class="controls">
  <button class="btn" id="prev">← Prev</button>
  <button class="btn" id="next">Next →</button>
  <button class="btn" id="notesBtn">Notes (N)</button>
  <button class="btn" id="fsBtn">Fullscreen (F)</button>
</div>
<div class="progress"><span id="bar"></span></div>

<script>
  (function () {
    const body = document.body;
    const backBtn = document.getElementById('backBtn');
    const curr  = document.getElementById('curr');
    const tot   = document.getElementById('total');
    const bar   = document.getElementById('bar');
    const notes = document.getElementById('notes');
    const notesContent = document.getElementById('notes-content');

    // ---------- Decks (one per path) ----------
    const decks = {
      general:  { slides: Array.from(document.querySelectorAll('#deck .slide')),          i: 0 },
      internal: { slides: Array.from(document.querySelectorAll('#deck-internal .slide')), i: 0 },
    };

    function activeDeck() {
      return decks[body.dataset.route] || null;
    }

    function render() {
      const deck = activeDeck();
      if (!deck) return;
      const total = deck.slides.length;
      deck.slides.forEach((s, idx) => s.classList.toggle('active', idx === deck.i));
      curr.textContent = deck.i + 1;
      tot.textContent  = total;
      bar.style.width  = ((deck.i + 1) / total * 100) + '%';
      const n = deck.slides[deck.i] && deck.slides[deck.i].dataset.notes || '';
      notesContent.innerHTML = n
        ? '<p>' + n.replace(/\n/g, '</p><p>') + '</p>'
        : '<p><em>No notes for this slide.</em></p>';
    }

    function go(delta) {
      const deck = activeDeck();
      if (!deck) return;
      deck.i = Math.max(0, Math.min(deck.slides.length - 1, deck.i + delta));
      render();
    }

    // ---------- Path routing ----------
    function setRoute(route) {
      body.dataset.route = route;
      backBtn.classList.toggle('visible', route !== 'landing');
      if (route === 'general' || route === 'internal') {
        // Reset to first slide each time a path is entered
        decks[route].i = 0;
        render();
      }
    }

    document.querySelectorAll('.path-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const path = btn.dataset.path;
        if (path === 'general' || path === 'internal') setRoute(path);
      });
    });

    backBtn.addEventListener('click', () => setRoute('landing'));

    // ---------- Step-by-step guide tree ----------
    function activateStep(step) {
      const slide = document.querySelector('.tree-step[data-step="' + step + '"]');
      const slideEl = slide && slide.closest('.slide');
      if (!slide || !slideEl) return;
      slideEl.querySelectorAll('.tree-step').forEach((b) => b.classList.toggle('active', b.dataset.step === step));
      slideEl.querySelectorAll('.step-panel').forEach((p) => p.classList.toggle('active', p.dataset.step === step));
    }

    function syncParentCheck() {
      // When any sub-option (1.3a, 1.3b) is checked, mark the parent (1.3) checked too.
      const parents = [
        { parent: '1.3', children: ['1.3a', '1.3b'] },
        { parent: '2.4', children: ['2.4a', '2.4b'] },
      ];
      parents.forEach(({ parent, children }) => {
        const parentEl = document.querySelector('.tree-step[data-step="' + parent + '"]');
        if (!parentEl) return;
        const anyChildDone = children.some((c) => {
          const el = document.querySelector('.tree-step[data-step="' + c + '"]');
          return el && el.classList.contains('done');
        });
        if (anyChildDone) parentEl.classList.add('done');
      });
    }

    document.querySelectorAll('.tree-step').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        // Clicking the checkbox toggles "done" without navigating
        if (e.target.closest('.step-check')) {
          btn.classList.toggle('done');
          syncParentCheck();
          return;
        }
        activateStep(btn.dataset.step);
      });
    });

    // Option A / Option B boxes inside step 1.3 jump to their sub-step
    document.querySelectorAll('.tree-jump').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        activateStep(btn.dataset.jump);
      });
    });

    const treeReset = document.getElementById('tree-reset');
    if (treeReset) {
      treeReset.addEventListener('click', (e) => {
        e.stopPropagation();
        document.querySelectorAll('.tree-step.done').forEach((b) => b.classList.remove('done'));
      });
    }

    // ---------- Copy-to-clipboard for code blocks ----------
    document.querySelectorAll('.code-block .copy-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const pre = btn.parentElement.querySelector('pre');
        if (!pre) return;
        try {
          await navigator.clipboard.writeText(pre.innerText);
          const original = btn.textContent;
          btn.textContent = 'Copied!';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove('copied');
          }, 1500);
        } catch (err) {
          // Fallback: select the text so the user can copy manually
          const range = document.createRange();
          range.selectNodeContents(pre);
          const sel = window.getSelection();
          sel.removeAllRanges();
          sel.addRange(range);
        }
      });
    });

    document.getElementById('prev').onclick = () => go(-1);
    document.getElementById('next').onclick = () => go(+1);
    document.getElementById('notesBtn').onclick = () => notes.classList.toggle('visible');
    document.getElementById('fsBtn').onclick = () => {
      if (!document.fullscreenElement) document.documentElement.requestFullscreen();
      else document.exitFullscreen();
    };

    document.addEventListener('keydown', (e) => {
      // Always allow Esc to return to landing
      if (e.key === 'Escape' && body.dataset.route !== 'landing') {
        setRoute('landing');
        return;
      }
      const deck = activeDeck();
      if (!deck) return;

      if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown') { e.preventDefault(); go(+1); }
      else if (e.key === 'ArrowLeft' || e.key === 'PageUp') { e.preventDefault(); go(-1); }
      else if (e.key === 'Home') { deck.i = 0; render(); }
      else if (e.key === 'End')  { deck.i = deck.slides.length - 1; render(); }
      else if (e.key.toLowerCase() === 'n') notes.classList.toggle('visible');
      else if (e.key.toLowerCase() === 'f') {
        if (!document.fullscreenElement) document.documentElement.requestFullscreen();
        else document.exitFullscreen();
      }
    });

    // Touch swipe — deck only
    let x0 = null;
    document.addEventListener('touchstart', (e) => { x0 = e.changedTouches[0].clientX; });
    document.addEventListener('touchend', (e) => {
      if (x0 == null) return;
      if (!activeDeck()) { x0 = null; return; }
      const dx = e.changedTouches[0].clientX - x0;
      if (Math.abs(dx) > 50) go(dx < 0 ? +1 : -1);
      x0 = null;
    });

    // Initial state: landing screen
    setRoute('landing');
  })();
</script>

</body>
</html>
